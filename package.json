{
  "name": "payload-custom-auth",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8000 next build",
    "dev": "next dev --turbo --no-server-fast-refresh",
    "devsafe": "rm -rf .next && next dev",
    "db:migrate": "cross-env PAYLOAD_SKIP_SEED=true payload migrate",
    "db:migrate:create": "cross-env PAYLOAD_SKIP_SEED=true payload migrate:create",
    "db:migrate:status": "cross-env PAYLOAD_SKIP_SEED=true payload migrate:status",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "generate:importmap": "cross-env PAYLOAD_SKIP_SEED=true payload generate:importmap",
    "generate:types": "cross-env PAYLOAD_SKIP_SEED=true payload generate:types",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "auth:migrate": "pnpm dlx auth@latest migrate",
    "payload": "payload",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=--no-experimental-strip-types pnpm exec playwright test",
    "test:int": "vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@daveyplate/better-auth-ui": "^3.4.0",
    "@payloadcms/db-postgres": "^3.81.0",
    "@payloadcms/next": "3.81.0",
    "@payloadcms/payload-cloud": "3.81.0",
    "@payloadcms/richtext-lexical": "3.81.0",
    "@payloadcms/ui": "3.81.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.2.2",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "17.4.0",
    "graphql": "^16.13.2",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "next-themes": "^0.4.6",
    "payload": "3.81.0",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "husky": "^9.1.7",
    "jsdom": "29.0.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "playwright": "1.59.1",
    "playwright-core": "1.59.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=24.9.0",
    "pnpm": "^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "dompurify@<=3.3.1": ">=3.3.2",
      "nodemailer@<8.0.4": ">=8.0.4",
      "esbuild@<=0.24.2": ">=0.25.0"
    }
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts,jsx,tsx,mjs,cjs}": "oxlint"
  }
}
