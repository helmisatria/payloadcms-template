{
  "name": "payload-better-auth",
  "version": "1.0.0",
  "description": "Payload CMS + PostgreSQL + Better Auth starter template with RBAC, social login, and session management",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8000 next build",
    "dev": "next dev --turbo --no-server-fast-refresh",
    "devsafe": "rm -rf .next && next dev",
    "db:setup": "pnpm db:migrate && pnpm db:seed",
    "db:migrate": "payload migrate",
    "db:migrate:create": "payload migrate:create",
    "db:migrate:fresh": "payload migrate:fresh",
    "db:migrate:status": "payload migrate:status",
    "db:seed": "payload run src/seeds/run.ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "generate:importmap": "payload generate:importmap",
    "generate:types": "payload generate:types",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "payload": "payload",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=--no-experimental-strip-types pnpm exec playwright test",
    "test:int": "vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@daveyplate/better-auth-ui": "^3.4.0",
    "@payloadcms/db-postgres": "^3.86.0",
    "@payloadcms/next": "3.86.0",
    "@payloadcms/payload-cloud": "3.86.0",
    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/ui": "3.86.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/postcss": "^4.3.2",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "17.4.2",
    "graphql": "^16.14.2",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "payload": "3.86.0",
    "payload-auditor": "1.11.0",
    "pg": "^8.22.0",
    "postcss": "^8.5.19",
    "react": "19.2.7",
    "react-diff-viewer-continued": "^4.3.0",
    "react-dom": "19.2.7",
    "sharp": "0.35.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^25.9.5",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "husky": "^9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "playwright": "1.61.1",
    "playwright-core": "1.61.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24.9.0",
    "pnpm": ">=10"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts,jsx,tsx,mjs,cjs}": "oxlint"
  }
}
